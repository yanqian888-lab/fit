# 服务器配置
PORT=3000
NODE_ENV=development

# JWT 密钥
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 豆包 / 火山引擎 API 配置
# 方式一：所有接入点共用一个 API Key
DOUBAO_API_KEY=your-doubao-api-key

# 方式二：每个接入点使用独立 API Key（优先级高于 DOUBAO_API_KEY）
DOUBAO_MAIN_AGENT_API_KEY=your-doubao-api-key
DOUBAO_PRECIPITATION_API_KEY=your-doubao-api-key
DOUBAO_HELPER_API_KEY=your-doubao-api-key

# 推理接入点 Endpoint ID，形如 ep-2026xxxxxx-xxxxx
DOUBAO_MAIN_AGENT_ENDPOINT=ep-xxxxxx
DOUBAO_PRECIPITATION_ENDPOINT=ep-xxxxxx
DOUBAO_HELPER_ENDPOINT=ep-xxxxxx

# 火山引擎 API 基础地址
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# 腾讯云 COS 配置（可选）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-bucket-name
COS_REGION=ap-guangzhou
COS_DOMAIN=https://your-bucket.cos.ap-guangzhou.myqcloud.com

# 数据库配置
DB_PATH=./data/app.db
