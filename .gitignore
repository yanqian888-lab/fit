# Dependencies
backend/node_modules/
frontend/node_modules/
frontend/dist/
frontend/unpackage/

# Environment variables
backend/.env
frontend/.env
*.env.local

# Database
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm

# Uploads
backend/uploads/*
!backend/uploads/.gitkeep

# Android signing certs - never push real certs
android-certs/*.keystore
android-certs/*.jks

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.AppleDouble
.LSOverride

# HBuilderX
.hbuilderx/

# UniApp
unpackage/

# Python venv
.venv/
venv/
__pycache__/

# Misc
*.tmp
*.temp
